# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Database (Neon → Connection Details → connection string) ---
DATABASE_URL=postgresql://[USER]:[PASSWORD]@ep-[ENDPOINT].[REGION].aws.neon.tech/[DB]?sslmode=require

# --- Embeddings (M1) --- (Gemini reuses GOOGLE_API_KEY below; £0)
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768
# OPENAI_API_KEY=   # only if you switch EMBEDDING_PROVIDER=openai

# --- Generation LLM (M2) ---
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash-lite
GOOGLE_API_KEY=

# --- Retrieval ---
TOP_K=4
